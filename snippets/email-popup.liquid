<!-- Overflow Email Popup — DROP20 -->
{%- unless customer -%}
{%- comment -%}Show success if user just signed up (redirected back with ?customer_posted=true){%- endcomment -%}
{%- if form.posted_successfully? -%}
  <script>
    document.addEventListener('DOMContentLoaded',function(){
      var ck='ov_popup_seen';
      var e=new Date();e.setDate(e.getDate()+365);
      document.cookie=ck+'=1;expires='+e.toUTCString()+';path=/;SameSite=Lax';
    });
  </script>
  <div id="ov-popup-overlay" style="display:flex;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.55);backdrop-filter:blur(2px);-webkit-backdrop-filter:blur(2px);align-items:center;justify-content:center;">
    <div style="background:#fff;max-width:400px;width:90%;margin:auto;padding:36px 28px;text-align:center;font-family:Arial,Helvetica,sans-serif;position:relative;">
      <button onclick="this.closest('[id]').parentElement.style.display='none'" style="position:absolute;top:10px;right:14px;background:none;border:none;font-size:22px;cursor:pointer;color:#000;line-height:1;">&times;</button>
      <h2 style="font-size:24px;font-weight:700;margin:0 0 12px;text-transform:uppercase;">You're in.</h2>
      <p style="font-size:14px;color:#333;margin:0 0 18px;line-height:1.5;">Your code <strong>DROP20</strong> gets you 20% off your first order.</p>
      <div style="background:#f5f5f5;padding:14px 16px;margin:0 0 20px;">
        <p style="font-size:22px;font-weight:700;margin:0;letter-spacing:2px;">DROP20</p>
      </div>
      <a href="/" style="display:inline-block;background:#000;color:#fff;padding:14px 40px;font-size:13px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;text-decoration:none;">Start Shopping</a>
    </div>
  </div>
{%- else -%}
<div id="ov-popup-overlay" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.55);backdrop-filter:blur(2px);-webkit-backdrop-filter:blur(2px);align-items:center;justify-content:center;">
  <div id="ov-popup" style="background:#fff;max-width:400px;width:90%;margin:auto;padding:32px 28px 28px;position:relative;text-align:center;font-family:Arial,Helvetica,sans-serif;">
    <button id="ov-popup-close" aria-label="Close" style="position:absolute;top:10px;right:14px;background:none;border:none;font-size:22px;cursor:pointer;color:#000;line-height:1;">&times;</button>
    <p style="font-size:11px;letter-spacing:2px;text-transform:uppercase;margin:0 0 12px;color:#555;">Welcome to</p>
    <h2 style="font-size:26px;font-weight:700;margin:0 0 14px;letter-spacing:-0.5px;text-transform:uppercase;">Overflow</h2>
    <p style="font-size:13px;line-height:1.55;color:#333;margin:0 0 18px;">Snap a photo of your stuff. We list it instantly. New drops every day with unique finds you won't see anywhere else.</p>
    <div style="background:#f5f5f5;padding:14px 16px;margin:0 0 20px;">
      <p style="font-size:11px;letter-spacing:1.5px;text-transform:uppercase;margin:0 0 4px;color:#555;">Your first-purchase code</p>
      <p style="font-size:22px;font-weight:700;margin:0;letter-spacing:2px;">DROP20</p>
      <p style="font-size:12px;color:#666;margin:4px 0 0;">20% off your first order</p>
    </div>
    {% form 'customer', id: 'ov-popup-form', return_to: request.path %}
      {{ form.errors | default_errors }}
      <input type="hidden" name="customer[tags]" value="drop20-popup,newsletter,prospect">
      <input id="ov-popup-email" name="customer[email]" type="email" required placeholder="Enter your email" autocomplete="email"
        style="width:100%;box-sizing:border-box;padding:12px 14px;border:1px solid #000;font-size:14px;font-family:Arial,Helvetica,sans-serif;margin:0 0 10px;outline:none;">
      <button type="submit" id="ov-popup-submit" style="width:100%;padding:12px 0;background:#000;color:#fff;border:none;font-size:13px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;font-family:Arial,Helvetica,sans-serif;">Get 20% Off</button>
    {% endform %}
    <p style="font-size:10px;color:#999;margin:14px 0 0;">No spam. Just drops.</p>
  </div>
</div>
<script>
(function(){
  var DELAY=4000,COOKIE='ov_popup_seen';
  function getCk(n){return document.cookie.split(';').some(function(c){return c.trim().startsWith(n+'=')});}
  function setCk(n,d){var e=new Date();e.setDate(e.getDate()+d);document.cookie=n+'=1;expires='+e.toUTCString()+';path=/;SameSite=Lax';}
  if(getCk(COOKIE))return;
  var overlay=document.getElementById('ov-popup-overlay');
  if(!overlay)return;
  setTimeout(function(){overlay.style.display='flex';},DELAY);
  var closeBtn=document.getElementById('ov-popup-close');
  if(closeBtn)closeBtn.addEventListener('click',function(){overlay.style.display='none';setCk(COOKIE,7);});
  overlay.addEventListener('click',function(e){if(e.target===overlay){overlay.style.display='none';setCk(COOKIE,7);}});
  document.addEventListener('keydown',function(e){if(e.key==='Escape'&&overlay.style.display==='flex'){overlay.style.display='none';setCk(COOKIE,7);}});
  var btn=document.getElementById('ov-popup-submit');
  if(btn)btn.addEventListener('click',function(){setTimeout(function(){btn.textContent='...';},50);});
})();
</script>
{%- endif -%}
{%- endunless -%}
