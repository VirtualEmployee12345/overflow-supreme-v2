<!-- Overflow Email Popup — DROP20 -->
{%- unless customer -%}
<div id="ov-popup-overlay" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.55);backdrop-filter:blur(2px);-webkit-backdrop-filter:blur(2px);align-items:center;justify-content:center;">
  <div id="ov-popup" style="background:#fff;max-width:400px;width:90%;margin:auto;padding:32px 28px 28px;position:relative;text-align:center;font-family:Arial,Helvetica,sans-serif;">
    <button id="ov-popup-close" aria-label="Close" style="position:absolute;top:10px;right:14px;background:none;border:none;font-size:22px;cursor:pointer;color:#000;line-height:1;">&times;</button>
    <p style="font-size:11px;letter-spacing:2px;text-transform:uppercase;margin:0 0 12px;color:#555;">Welcome to</p>
    <h2 style="font-size:26px;font-weight:700;margin:0 0 14px;letter-spacing:-0.5px;text-transform:uppercase;">Overflow</h2>
    <p style="font-size:13px;line-height:1.55;color:#333;margin:0 0 18px;">Snap a photo of your stuff. We list it instantly. New drops every day with unique finds you won't see anywhere else.</p>
    <div style="background:#f5f5f5;padding:14px 16px;margin:0 0 20px;">
      <p style="font-size:11px;letter-spacing:1.5px;text-transform:uppercase;margin:0 0 4px;color:#555;">Your first-purchase code</p>
      <p style="font-size:22px;font-weight:700;margin:0;letter-spacing:2px;">DROP20</p>
      <p style="font-size:12px;color:#666;margin:4px 0 0;">20% off your first order</p>
    </div>
    <form id="ov-popup-form" style="margin:0;">
      <input id="ov-popup-email" type="email" required placeholder="Enter your email" autocomplete="email"
        style="width:100%;box-sizing:border-box;padding:12px 14px;border:1px solid #000;font-size:14px;font-family:Arial,Helvetica,sans-serif;margin:0 0 10px;outline:none;">
      <button type="submit" style="width:100%;padding:12px 0;background:#000;color:#fff;border:none;font-size:13px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;font-family:Arial,Helvetica,sans-serif;">Get 20% Off</button>
    </form>
    <p id="ov-popup-success" style="display:none;font-size:13px;color:#000;margin:14px 0 0;font-weight:600;">You're in. Check your email for DROP20.</p>
    <p id="ov-popup-error" style="display:none;font-size:12px;color:#c00;margin:10px 0 0;"></p>
    <p style="font-size:10px;color:#999;margin:14px 0 0;">No spam. Just drops.</p>
  </div>
</div>
<script>
(function(){
  var DELAY = 4000;
  var COOKIE = 'ov_popup_seen';
  function getCk(n){return document.cookie.split(';').some(function(c){return c.trim().startsWith(n+'=')});}
  function setCk(n,d){var e=new Date();e.setDate(e.getDate()+d);document.cookie=n+'=1;expires='+e.toUTCString()+';path=/;SameSite=Lax';}
  if(getCk(COOKIE)) return;
  var overlay=document.getElementById('ov-popup-overlay');
  if(!overlay) return;
  setTimeout(function(){overlay.style.display='flex';},DELAY);
  document.getElementById('ov-popup-close').addEventListener('click',function(){overlay.style.display='none';setCk(COOKIE,7);});
  overlay.addEventListener('click',function(e){if(e.target===overlay){overlay.style.display='none';setCk(COOKIE,7);}});
  document.addEventListener('keydown',function(e){if(e.key==='Escape'&&overlay.style.display==='flex'){overlay.style.display='none';setCk(COOKIE,7);}});
  document.getElementById('ov-popup-form').addEventListener('submit',function(e){
    e.preventDefault();
    var email=document.getElementById('ov-popup-email').value.trim();
    var errEl=document.getElementById('ov-popup-error');
    var succEl=document.getElementById('ov-popup-success');
    errEl.style.display='none';
    if(!email){errEl.textContent='Please enter your email.';errEl.style.display='block';return;}
    var btn=this.querySelector('button[type="submit"]');
    btn.textContent='...';btn.disabled=true;
    fetch('/contact#contact_form',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},
      body:'form_type=customer&utf8=%E2%9C%93&customer%5Bemail%5D='+encodeURIComponent(email)+'&customer%5Btags%5D=drop20-popup'
    }).then(function(r){
      if(r.ok||r.status===302||r.status===200){
        document.getElementById('ov-popup-form').style.display='none';
        succEl.style.display='block';
        setCk(COOKIE,365);
        setTimeout(function(){overlay.style.display='none';},3500);
      } else {
        throw new Error('status '+r.status);
      }
    }).catch(function(){
      errEl.textContent='Something went wrong. Try again.';errEl.style.display='block';
      btn.textContent='GET 20% OFF';btn.disabled=false;
    });
  });
})();
</script>
{%- endunless -%}