{% comment %}
  collection-drop-photo.liquid
  Used by templates/collection.drop.json

  Reads two metafields from the collection:
    - custom.hero_photo_url  (string) → CDN URL of the source photo
    - custom.hotspots        (json)   → array of hotspot objects

  Hotspot JSON format:
  [
    {"left": 19.2, "top": 57.3, "handle": "fayleeko-key-lock-box",
     "title": "Fayleeko Key Lock Box", "price": "$24.99",
     "img": "https://cdn.shopify.com/..."},
    ...
  ]

  FIX: metafield type=json → use | json filter to emit valid JSON string into <script>
{% endcomment %}

{%- assign hero_url      = collection.metafields.custom.hero_photo_url.value -%}
{%- assign hotspots_data = collection.metafields.custom.hotspots.value -%}

{%- comment -%} Clean display title: remove dashes, strip "Drop " prefix formatting {%- endcomment -%}
{%- assign display_title = collection.title | remove: '-' -%}

<style>
  .drop-page {
    background: #fff;
    font-family: Arial, Helvetica, sans-serif;
    padding-bottom: 60px;
  }

  /* ── Title bar ── */
  .drop-title-bar {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 24px 24px 12px;
    border-bottom: 2px solid #000;
  }
  .drop-title-bar h1 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #000;
    margin: 0;
  }
  .drop-title-bar-links {
    display: flex;
    gap: 20px;
    align-items: center;
  }
  .drop-title-bar-links a {
    font-size: 11px;
    color: #000;
    text-decoration: underline;
    letter-spacing: 0.04em;
  }
  .drop-title-bar .drop-meta {
    font-size: 10px;
    color: #888;
    letter-spacing: 0.06em;
  }

  /* ── Photo wrapper ── */
  .drop-photo-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #111;
    display: block;
  }
  .drop-hero {
    width: 100%;
    height: auto;
    display: block;
    max-height: 80vh;
    object-fit: cover;
    object-position: center;
  }

  /* ── HOTSPOT ZONE — large clickable area ── */
  .drop-hotspot-zone {
    position: absolute;
    width: 80px;
    height: 80px;
    transform: translate(-50%, -50%);
    cursor: pointer;
    z-index: 20;
    text-decoration: none;
    -webkit-tap-highlight-color: rgba(212,2,29,0.2);
  }

  /* Red pulsing dot */
  .drop-hotspot-zone::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 22px; height: 22px;
    background: #d4021d;
    border: 3px solid #fff;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: transform 0.15s, background 0.15s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.35);
  }

  /* Ripple ring */
  .drop-hotspot-zone::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 22px; height: 22px;
    border: 2px solid #d4021d;
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.7;
    animation: drop-ripple 2s ease-out infinite;
  }

  @keyframes drop-ripple {
    0%   { transform: translate(-50%, -50%) scale(1);   opacity: 0.7; }
    100% { transform: translate(-50%, -50%) scale(2.8); opacity: 0; }
  }

  .drop-hotspot-zone:hover::before,
  .drop-hotspot-zone:focus::before {
    transform: translate(-50%, -50%) scale(1.3);
    background: #a80118;
  }
  .drop-hotspot-zone:hover::after,
  .drop-hotspot-zone:focus::after {
    animation: none;
    opacity: 0;
  }

  /* ── Hover label ── */
  .drop-hotspot-label {
    position: absolute;
    bottom: calc(50% + 18px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    background: #000;
    color: #fff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 5px 9px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
    z-index: 30;
  }
  .drop-hotspot-label span {
    color: #aaa;
    margin-left: 6px;
    font-weight: 400;
  }
  .drop-hotspot-label::after {
    content: '';
    position: absolute;
    top: 100%; left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: #000;
  }
  .drop-hotspot-zone:hover .drop-hotspot-label,
  .drop-hotspot-zone:focus .drop-hotspot-label {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* Mobile */
  @media (max-width: 600px) {
    .drop-hotspot-zone { width: 64px; height: 64px; }
    .drop-hotspot-zone::before { width: 18px; height: 18px; }
    .drop-hero { max-height: 70vw; }
  }

  /* ── No photo state ── */
  .drop-no-photo {
    padding: 60px 24px;
    text-align: center;
    font-size: 11px;
    color: #888;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ── Product grid ── */
  .drop-grid-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 24px 24px 12px;
    border-top: 1px solid #e8e8e8;
  }
  .drop-grid-header h2 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #000;
    margin: 0;
  }
  .drop-grid-header-links {
    display: flex;
    gap: 20px;
  }
  .drop-grid-header-links a {
    font-size: 11px;
    color: #000;
    text-decoration: underline;
    letter-spacing: 0.04em;
  }
  .drop-product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0;
    padding: 0 24px;
  }
  .drop-product-card {
    padding: 12px 8px;
    text-decoration: none;
    display: block;
    border-right: 1px solid #e8e8e8;
    transition: background 0.1s;
  }
  .drop-product-card:last-child { border-right: none; }
  .drop-product-card:hover { background: #f7f7f7; }
  .drop-product-card img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
    background: #f0f0f0;
    margin-bottom: 8px;
  }
  .drop-product-card-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #000;
    margin: 0 0 3px;
    line-height: 1.3;
  }
  .drop-product-card-price { font-size: 10px; color: #000; }

  @media (max-width: 600px) {
    .drop-product-grid { grid-template-columns: repeat(2, 1fr); padding: 0 12px; }
  }
</style>

<div class="drop-page">

  <div class="drop-title-bar">
    <h1>{{ display_title }}</h1>
    <div class="drop-title-bar-links">
      <span class="drop-meta">{{ collection.products_count }} item{% if collection.products_count != 1 %}s{% endif %}</span>
    </div>
  </div>

  {%- if hero_url != blank -%}
    <div class="drop-photo-wrapper" id="drop-wrapper">
      <img class="drop-hero" src="{{ hero_url }}" alt="{{ display_title }}" loading="eager">
      {%- if hotspots_data != blank -%}
        {%- comment -%}
          KEY FIX: use `| json` to serialize the Liquid object back to a valid JSON string.
          Without this, Liquid renders the array as a Ruby-style object, not JSON.
        {%- endcomment -%}
        <script id="drop-hotspots-data" type="application/json">{{ hotspots_data | json }}</script>
      {%- endif -%}
    </div>
  {%- else -%}
    <div class="drop-no-photo">Photo coming soon</div>
  {%- endif -%}

  {%- if collection.products_count > 0 -%}
    <div class="drop-grid-header">
      <h2>Items in this drop</h2>
      <div class="drop-grid-header-links">
        <a href="/pages/drops">All drops</a>
        <a href="/collections/all">Shop all</a>
      </div>
    </div>
    <div class="drop-product-grid">
      {%- for product in collection.products -%}
        <a href="{{ product.url }}" class="drop-product-card">
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" loading="lazy">
          {%- else -%}
            <div style="width:100%;aspect-ratio:1;background:#f0f0f0;"></div>
          {%- endif -%}
          <p class="drop-product-card-title">{{ product.title }}</p>
          <p class="drop-product-card-price">{{ product.price | money }}</p>
        </a>
      {%- endfor -%}
    </div>
  {%- endif -%}

</div>

{%- if hero_url != blank -%}
<script>
(function() {
  var wrapper = document.getElementById('drop-wrapper');
  var dataEl  = document.getElementById('drop-hotspots-data');
  if (!wrapper || !dataEl) return;

  var hotspots;
  try {
    var raw = dataEl.textContent.trim();
    hotspots = JSON.parse(raw);
  } catch(e) {
    console.warn('Overflow: could not parse hotspots JSON', e);
    return;
  }
  if (!Array.isArray(hotspots) || hotspots.length === 0) return;

  hotspots.forEach(function(hs) {
    var zone = document.createElement('a');
    zone.className  = 'drop-hotspot-zone';
    zone.href       = '/products/' + hs.handle;
    zone.style.left = hs.left + '%';
    zone.style.top  = hs.top  + '%';
    zone.setAttribute('aria-label', hs.title + ' — ' + hs.price);

    var label = document.createElement('span');
    label.className = 'drop-hotspot-label';
    label.innerHTML = hs.title + '<span>' + hs.price + '</span>';
    zone.appendChild(label);

    wrapper.appendChild(zone);
  });
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Drop — Shop the Photo",
  "tag": "section",
  "class": "section-drop-photo",
  "settings": [],
  "presets": [{"name": "Drop — Shop the Photo"}]
}
{% endschema %}
