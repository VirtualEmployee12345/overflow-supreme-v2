{% comment %}
  collection-drop-photo.liquid
  Used by templates/collection.drop.json

  Reads two metafields from the collection:
    - custom.hero_photo_url  (string) → CDN URL of the source photo
    - custom.hotspots        (json)   → array of hotspot objects

  Styled to match the homepage shop-the-photo section exactly:
  full-bleed hero, gradient overlay, inline prev/next arrows.
{% endcomment %}

{%- assign hero_url      = collection.metafields.custom.hero_photo_url.value -%}
{%- assign hotspots_data = collection.metafields.custom.hotspots.value -%}
{%- assign display_title = collection.title | remove: '-' -%}

{%- comment -%} Build sorted drop list for prev/next navigation {%- endcomment -%}
{%- assign drop_nav_data = '' -%}
{%- assign drop_sep = '|||' -%}
{%- for col in collections -%}
  {%- if col.handle contains 'drop-' -%}
    {%- assign drop_entry = col.handle | append: '::' | append: col.title | append: '::' | append: col.url -%}
    {%- if drop_nav_data == '' -%}
      {%- assign drop_nav_data = drop_entry -%}
    {%- else -%}
      {%- assign drop_nav_data = drop_nav_data | append: drop_sep | append: drop_entry -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

<style>
  /* ── Reset section so it bleeds edge-to-edge with no gaps ── */
  .cdp-section {
    font-family: Arial, Helvetica, sans-serif;
    background: #fff;
  }

  /* ── Full-bleed hero wrapper ── */
  .cdp-photo-wrapper {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background: #111;
    display: block;
  }

  /* Image fills entire wrapper */
  .cdp-hero {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Subtle gradient at top so text is legible over bright photos */
  .cdp-photo-wrapper::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.38) 0%,
      rgba(0,0,0,0.10) 18%,
      rgba(0,0,0,0) 36%
    );
    z-index: 5;
    pointer-events: none;
  }

  /* ── Overlay UI bar at top of hero ── */
  .cdp-overlay-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 28px;
  }

  .cdp-overlay-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }
  .cdp-overlay-title:hover { opacity: 0.8; }

  .cdp-overlay-links {
    display: flex;
    gap: 20px;
    align-items: center;
  }
  .cdp-overlay-links a {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
    border-bottom: 1px solid rgba(255,255,255,0.5);
    padding-bottom: 1px;
  }
  .cdp-overlay-links a:hover { border-bottom-color: #fff; }

  /* ── Inline prev/next arrows ── */
  .cdp-nav-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    text-decoration: none;
    padding: 4px;
    transition: opacity 0.12s, transform 0.12s;
    filter: drop-shadow(0 1px 3px rgba(0,0,0,0.4));
    flex-shrink: 0;
    visibility: hidden;
  }
  .cdp-nav-arrow:hover { opacity: 0.7; }
  .cdp-nav-arrow--prev:hover { transform: translateX(-2px); }
  .cdp-nav-arrow--next:hover { transform: translateX(2px); }
  .cdp-nav-arrow--disabled {
    opacity: 0.25;
    pointer-events: none;
    cursor: default;
  }

  /* ── Hotspot zones ── */
  .cdp-hotspot-zone {
    position: absolute;
    width: 80px;
    height: 80px;
    transform: translate(-50%, -50%);
    cursor: pointer;
    z-index: 20;
    text-decoration: none;
    -webkit-tap-highlight-color: rgba(212,2,29,0.2);
  }
  .cdp-hotspot-zone::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 22px; height: 22px;
    background: #d4021d;
    border: 3px solid #fff;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: transform 0.15s, background 0.15s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.35);
  }
  .cdp-hotspot-zone::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 22px; height: 22px;
    border: 2px solid #d4021d;
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.7;
    animation: cdp-ripple 2s ease-out infinite;
  }
  @keyframes cdp-ripple {
    0%   { transform: translate(-50%,-50%) scale(1);   opacity: 0.7; }
    100% { transform: translate(-50%,-50%) scale(2.8); opacity: 0; }
  }
  .cdp-hotspot-zone:hover::before,
  .cdp-hotspot-zone:focus::before {
    transform: translate(-50%, -50%) scale(1.3);
    background: #a80118;
  }
  .cdp-hotspot-zone:hover::after,
  .cdp-hotspot-zone:focus::after { animation: none; opacity: 0; }

  /* Hover label */
  .cdp-hotspot-label {
    position: absolute;
    bottom: calc(50% + 18px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    background: #000;
    color: #fff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 5px 9px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s, transform 0.15s;
    z-index: 30;
  }
  .cdp-hotspot-label span { color: #aaa; margin-left: 6px; font-weight: 400; }
  .cdp-hotspot-label::after {
    content: '';
    position: absolute;
    top: 100%; left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: #000;
  }
  .cdp-hotspot-zone:hover .cdp-hotspot-label,
  .cdp-hotspot-zone:focus .cdp-hotspot-label { opacity: 1; transform: translateX(-50%) translateY(0); }

  /* ── Product grid ── */
  .cdp-grid-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 28px 24px 12px;
    border-top: 1px solid #e8e8e8;
  }
  .cdp-grid-header h2 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #000;
    margin: 0;
  }
  .cdp-grid-links { display: flex; gap: 20px; align-items: center; }
  .cdp-grid-links a {
    font-size: 11px;
    color: #000;
    text-decoration: underline;
    letter-spacing: 0.04em;
  }
  .cdp-product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0;
    padding: 0 24px;
  }
  .cdp-product-card {
    padding: 12px 8px;
    text-decoration: none;
    display: block;
    border-right: 1px solid #e8e8e8;
    transition: background 0.1s;
  }
  .cdp-product-card:last-child { border-right: none; }
  .cdp-product-card:hover { background: #f7f7f7; }
  .cdp-product-card img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
    background: #f5f5f5;
    margin-bottom: 8px;
  }
  .cdp-product-card-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #000;
    margin: 0 0 3px;
    line-height: 1.3;
  }
  .cdp-product-card-price { font-size: 10px; color: #000; }

  /* ── No photo state ── */
  .cdp-no-photo {
    padding: 60px 24px;
    text-align: center;
    font-size: 11px;
    color: #888;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (max-width: 600px) {
    .cdp-photo-wrapper {
      height: auto;
      overflow: visible;
    }
    .cdp-hero {
      position: relative;
      inset: auto;
      width: 100%;
      height: auto;
      object-fit: contain;
    }
    .cdp-hotspot-zone { width: 64px; height: 64px; }
    .cdp-hotspot-zone::before { width: 18px; height: 18px; }
    .cdp-product-grid { grid-template-columns: repeat(2, 1fr); }
    .cdp-overlay-bar { padding: 16px 16px; }
  }
</style>

<script id="cdp-drop-nav-data" type="application/json">
{
  "drops": {{ drop_nav_data | split: drop_sep | json }},
  "current": {{ collection.handle | json }}
}
</script>

<section class="cdp-section">

  {%- if hero_url != blank -%}
    <div class="cdp-photo-wrapper" id="cdp-wrapper">

      {%- comment -%} Full-bleed hero image {%- endcomment -%}
      <img class="cdp-hero" src="{{ hero_url }}" alt="{{ display_title }}" loading="eager">

      {%- comment -%} Overlay: prev arrow + drop title + nav links + next arrow {%- endcomment -%}
      <div class="cdp-overlay-bar">
        <a class="cdp-nav-arrow cdp-nav-arrow--prev" id="cdp-nav-prev" href="#" aria-label="Previous drop">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>

        <span class="cdp-overlay-title">{{ display_title }}</span>

        <div class="cdp-overlay-links">
          <a href="/pages/drops">View all</a>
          <a href="/collections/all">Shop all</a>
        </div>

        <a class="cdp-nav-arrow cdp-nav-arrow--next" id="cdp-nav-next" href="#" aria-label="Next drop">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      {%- comment -%} Hotspot data {%- endcomment -%}
      {%- if hotspots_data != blank -%}
        <script id="cdp-hotspots-data" type="application/json">{{ hotspots_data | json }}</script>
      {%- endif -%}

    </div>
  {%- else -%}
    <div class="cdp-no-photo">Photo coming soon</div>
  {%- endif -%}

  {%- comment -%} Product grid below hero {%- endcomment -%}
  {%- if collection.products_count > 0 -%}
    <div class="cdp-grid-header">
      <h2>{{ display_title }}</h2>
      <div class="cdp-grid-links">
        <a href="/pages/drops">View all</a>
        <a href="/collections/all">Shop all</a>
      </div>
    </div>
    <div class="cdp-product-grid">
      {%- for product in collection.products -%}
        <a href="{{ product.url }}" class="cdp-product-card">
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" loading="lazy">
          {%- else -%}
            <div style="width:100%;aspect-ratio:1;background:#f0f0f0;"></div>
          {%- endif -%}
          <p class="cdp-product-card-title">{{ product.title }}</p>
          <p class="cdp-product-card-price">{{ product.price | money }}</p>
        </a>
      {%- endfor -%}
    </div>
  {%- endif -%}

</section>

<script>
/* Hotspots */
(function() {
  var wrapper = document.getElementById('cdp-wrapper');
  var dataEl  = document.getElementById('cdp-hotspots-data');
  if (!wrapper || !dataEl) return;

  var hotspots;
  try { hotspots = JSON.parse(dataEl.textContent.trim()); }
  catch(e) { console.warn('Overflow: hotspot parse error', e); return; }
  if (!Array.isArray(hotspots) || hotspots.length === 0) return;

  hotspots.forEach(function(hs) {
    var zone = document.createElement('a');
    zone.className  = 'cdp-hotspot-zone';
    zone.href       = '/products/' + hs.handle;
    zone.style.left = hs.left + '%';
    zone.style.top  = hs.top  + '%';
    zone.setAttribute('aria-label', hs.title + ' — ' + hs.price);

    var label = document.createElement('span');
    label.className = 'cdp-hotspot-label';
    label.innerHTML = hs.title + '<span>' + hs.price + '</span>';
    zone.appendChild(label);
    wrapper.appendChild(zone);
  });
})();
</script>

<script>
/* Drop nav arrows (inline in overlay bar) */
(function() {
  var dataEl = document.getElementById('cdp-drop-nav-data');
  if (!dataEl) return;

  var data;
  try { data = JSON.parse(dataEl.textContent.trim()); }
  catch(e) { return; }

  var rawDrops = data.drops;
  var current  = data.current;
  if (!rawDrops || rawDrops.length === 0) return;

  var drops = rawDrops.map(function(d) {
    var parts = d.split('::');
    return { handle: parts[0], title: parts[1], url: parts[2] };
  });
  drops.sort(function(a, b) { return a.handle < b.handle ? -1 : 1; });

  var idx = drops.findIndex(function(d) { return d.handle === current; });
  if (idx === -1) idx = drops.length - 1;

  var prevEl = document.getElementById('cdp-nav-prev');
  var nextEl = document.getElementById('cdp-nav-next');

  if (idx > 0) {
    prevEl.href = drops[idx - 1].url;
    prevEl.style.visibility = 'visible';
  } else {
    prevEl.classList.add('cdp-nav-arrow--disabled');
    prevEl.style.visibility = 'visible';
  }

  if (idx < drops.length - 1) {
    nextEl.href = drops[idx + 1].url;
    nextEl.style.visibility = 'visible';
  } else {
    nextEl.classList.add('cdp-nav-arrow--disabled');
    nextEl.style.visibility = 'visible';
  }

  /* Swipe support */
  var wrapper = document.getElementById('cdp-wrapper');
  if (wrapper) {
    var touchStartX = null;
    wrapper.addEventListener('touchstart', function(e) {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    wrapper.addEventListener('touchend', function(e) {
      if (touchStartX === null) return;
      var dx = e.changedTouches[0].clientX - touchStartX;
      touchStartX = null;
      if (Math.abs(dx) < 50) return;
      if (dx < 0 && idx < drops.length - 1) window.location.href = drops[idx + 1].url;
      else if (dx > 0 && idx > 0) window.location.href = drops[idx - 1].url;
    }, { passive: true });
  }
})();
</script>

{% schema %}
{
  "name": "Drop — Shop the Photo",
  "tag": "section",
  "class": "section-drop-photo",
  "settings": [],
  "presets": [{"name": "Drop — Shop the Photo"}]
}
{% endschema %}

