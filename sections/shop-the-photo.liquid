{% comment %}
  shop-the-photo.liquid — Homepage hero section
  
  AUTO-UPDATES to the most recent drop every time a new drop is added.
  
  Finds the latest drop collection (handle starts with "drop-") by iterating
  all collections and picking the lexicographically largest handle.
  Reads hero_photo_url + hotspots from that collection's metafields.
  Falls back to section settings if no drop collections exist.
  
  Hotspot UX: large 80×80px clickable <a> zones — clicking goes directly
  to /products/{handle}. Hover shows compact label with title + price.
{% endcomment %}

{%- comment -%} ── Find latest drop collection ── {%- endcomment -%}
{%- assign latest_drop = nil -%}
{%- assign latest_handle = '' -%}
{%- for col in collections -%}
  {%- if col.handle contains 'drop-' -%}
    {%- if col.handle > latest_handle -%}
      {%- assign latest_handle = col.handle -%}
      {%- assign latest_drop = col -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%} ── Pull data from latest drop ── {%- endcomment -%}
{%- if latest_drop -%}
  {%- assign hero_url      = latest_drop.metafields.custom.hero_photo_url.value -%}
  {%- assign hotspots_data = latest_drop.metafields.custom.hotspots.value -%}
  {%- assign drop_title    = latest_drop.title | replace: '-', ' ' -%}
  {%- assign drop_url      = latest_drop.url -%}
  {%- assign drop_count    = latest_drop.products_count -%}
{%- else -%}
  {%- assign hero_url      = section.settings.photo_url -%}
  {%- assign hotspots_data = nil -%}
  {%- assign drop_title    = section.settings.heading | default: 'Shop the photo' -%}
  {%- assign drop_url      = '/collections/all' -%}
  {%- assign drop_count    = 0 -%}
{%- endif -%}

<style>
  .stp-section {
    background: #fff;
    padding: 0 0 60px 0;
    font-family: Arial, Helvetica, sans-serif;
  }

  /* ── Header ── */
  .stp-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 32px 24px 16px;
    border-bottom: 1px solid #e8e8e8;
  }
  .stp-header h2 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #000;
    margin: 0;
  }
  .stp-header h2 a {
    color: #000;
    text-decoration: none;
  }
  .stp-header h2 a:hover { color: #d4021d; }
  .stp-header-links {
    display: flex;
    gap: 20px;
    align-items: center;
  }
  .stp-header-links a {
    font-size: 11px;
    color: #000;
    text-decoration: underline;
    letter-spacing: 0.04em;
  }

  /* ── Photo Wrapper ── */
  .stp-photo-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #111;
  }
  .stp-hero {
    width: 100%;
    height: auto;
    display: block;
    max-height: 80vh;
    object-fit: cover;
    object-position: center;
  }

  /* ── Hotspot zones (large, direct-link) ── */
  .stp-hotspot-zone {
    position: absolute;
    width: 80px;
    height: 80px;
    transform: translate(-50%, -50%);
    cursor: pointer;
    z-index: 20;
    text-decoration: none;
    -webkit-tap-highlight-color: rgba(212,2,29,0.2);
  }
  .stp-hotspot-zone::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 22px; height: 22px;
    background: #d4021d;
    border: 3px solid #fff;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: transform 0.15s, background 0.15s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.35);
  }
  .stp-hotspot-zone::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 22px; height: 22px;
    border: 2px solid #d4021d;
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.7;
    animation: stp-ripple 2s ease-out infinite;
  }
  @keyframes stp-ripple {
    0%   { transform: translate(-50%,-50%) scale(1);   opacity: 0.7; }
    100% { transform: translate(-50%,-50%) scale(2.8); opacity: 0; }
  }
  .stp-hotspot-zone:hover::before,
  .stp-hotspot-zone:focus::before {
    transform: translate(-50%, -50%) scale(1.3);
    background: #a80118;
  }
  .stp-hotspot-zone:hover::after,
  .stp-hotspot-zone:focus::after {
    animation: none; opacity: 0;
  }

  /* Label on hover */
  .stp-hotspot-label {
    position: absolute;
    bottom: calc(50% + 18px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    background: #000;
    color: #fff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 5px 9px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s, transform 0.15s;
    z-index: 30;
  }
  .stp-hotspot-label span { color: #aaa; margin-left: 6px; font-weight: 400; }
  .stp-hotspot-label::after {
    content: '';
    position: absolute;
    top: 100%; left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: #000;
  }
  .stp-hotspot-zone:hover .stp-hotspot-label,
  .stp-hotspot-zone:focus .stp-hotspot-label {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 600px) {
    .stp-hotspot-zone { width: 64px; height: 64px; }
    .stp-hotspot-zone::before { width: 18px; height: 18px; }
    .stp-hero { max-height: 70vw; }
  }

  /* ── Product grid below photo ── */
  .stp-grid-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 28px 24px 12px;
    border-top: 1px solid #e8e8e8;
  }
  .stp-grid-header h3 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #000;
    margin: 0;
  }
  .stp-grid-links {
    display: flex;
    gap: 20px;
    align-items: center;
  }
  .stp-grid-links a {
    font-size: 11px;
    color: #000;
    text-decoration: underline;
    letter-spacing: 0.04em;
  }
  .stp-product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0;
    padding: 0 24px;
  }
  .stp-product-card {
    padding: 12px 8px;
    text-decoration: none;
    display: block;
    border-right: 1px solid #e8e8e8;
    transition: background 0.1s;
  }
  .stp-product-card:last-child { border-right: none; }
  .stp-product-card:hover { background: #f7f7f7; }
  .stp-product-card img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
    background: #f5f5f5;
    margin-bottom: 8px;
  }
  .stp-product-card-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #000;
    margin: 0 0 3px;
    line-height: 1.3;
  }
  .stp-product-card-price { font-size: 10px; color: #000; }

  @media (max-width: 600px) {
    .stp-product-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<section class="stp-section">

  {%- comment -%} Header: drop title links to the drop, links on right {%- endcomment -%}
  <div class="stp-header">
    <h2><a href="{{ drop_url }}">{{ drop_title }}</a></h2>
    <div class="stp-header-links">
      <a href="/pages/drops">View all drops</a>
      <a href="/collections/all">Shop all</a>
    </div>
  </div>

  {%- comment -%} Hero photo + hotspots {%- endcomment -%}
  {%- if hero_url != blank -%}
    <div class="stp-photo-wrapper" id="stp-wrapper">
      <img class="stp-hero" src="{{ hero_url }}" alt="{{ drop_title }}" loading="eager">
      {%- if hotspots_data != blank -%}
        <script id="stp-hotspots-data" type="application/json">{{ hotspots_data | json }}</script>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} Product grid from latest drop {%- endcomment -%}
  {%- if latest_drop and latest_drop.products_count > 0 -%}
    <div class="stp-grid-header">
      <h3>{{ drop_title }}</h3>
      <div class="stp-grid-links">
        <a href="/pages/drops">View all drops</a>
        <a href="/collections/all">Shop all</a>
      </div>
    </div>
    <div class="stp-product-grid">
      {%- for product in latest_drop.products -%}
        <a href="{{ product.url }}" class="stp-product-card">
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" loading="lazy">
          {%- endif -%}
          <p class="stp-product-card-title">{{ product.title }}</p>
          <p class="stp-product-card-price">{{ product.price | money }}</p>
        </a>
      {%- endfor -%}
    </div>
  {%- endif -%}

</section>

<script>
(function() {
  var wrapper = document.getElementById('stp-wrapper');
  var dataEl  = document.getElementById('stp-hotspots-data');
  if (!wrapper || !dataEl) return;

  var hotspots;
  try {
    hotspots = JSON.parse(dataEl.textContent.trim());
  } catch(e) {
    console.warn('Overflow: hotspot parse error', e);
    return;
  }
  if (!Array.isArray(hotspots) || hotspots.length === 0) return;

  hotspots.forEach(function(hs) {
    var zone = document.createElement('a');
    zone.className  = 'stp-hotspot-zone';
    zone.href       = '/products/' + hs.handle;
    zone.style.left = hs.left + '%';
    zone.style.top  = hs.top  + '%';
    zone.setAttribute('aria-label', hs.title + ' — ' + hs.price);

    var label = document.createElement('span');
    label.className = 'stp-hotspot-label';
    label.innerHTML = hs.title + '<span>' + hs.price + '</span>';
    zone.appendChild(label);

    wrapper.appendChild(zone);
  });
})();
</script>

{% schema %}
{
  "name": "Shop the Photo",
  "tag": "section",
  "class": "section-shop-the-photo",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Fallback heading",
      "default": "Shop the photo",
      "info": "Only shown if no drop collections exist yet."
    },
    {
      "type": "url",
      "id": "photo_url",
      "label": "Fallback photo URL",
      "info": "Only used if no drop collections exist."
    }
  ],
  "presets": [{"name": "Shop the Photo"}]
}
{% endschema %}
