{% comment %}
  shop-the-photo.liquid — Homepage hero section (full-bleed)
  
  Hero image fills 100vh edge-to-edge. Drop title, nav links and hotspot
  dots are all overlaid on top of the photo. Product grid sits below.
{% endcomment %}

{%- assign latest_drop = nil -%}
{%- assign latest_handle = '' -%}
{%- for col in collections -%}
  {%- if col.handle contains 'drop-' -%}
    {%- if col.handle > latest_handle -%}
      {%- assign latest_handle = col.handle -%}
      {%- assign latest_drop = col -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- if latest_drop -%}
  {%- assign hero_url      = latest_drop.metafields.custom.hero_photo_url.value -%}
  {%- assign hotspots_data = latest_drop.metafields.custom.hotspots.value -%}
  {%- assign drop_title    = latest_drop.title | remove: '-' -%}
  {%- assign drop_url      = latest_drop.url -%}
{%- else -%}
  {%- assign hero_url      = section.settings.photo_url -%}
  {%- assign hotspots_data = nil -%}
  {%- assign drop_title    = section.settings.heading | default: 'Shop the photo' -%}
  {%- assign drop_url      = '/collections/all' -%}
{%- endif -%}

<style>
  /* ── Reset section so it bleeds edge-to-edge with no gaps ── */
  .stp-section {
    font-family: Arial, Helvetica, sans-serif;
    background: #fff;
  }

  /* ── Full-bleed hero wrapper ── */
  .stp-photo-wrapper {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background: #111;
    display: block;
  }

  /* Image fills entire wrapper */
  .stp-hero {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Subtle gradient at top so text is legible over bright photos */
  .stp-photo-wrapper::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.38) 0%,
      rgba(0,0,0,0.10) 18%,
      rgba(0,0,0,0) 36%
    );
    z-index: 5;
    pointer-events: none;
  }

  /* ── Overlay UI bar at top of hero ── */
  .stp-overlay-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 28px;
  }

  .stp-overlay-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }
  .stp-overlay-title:hover { opacity: 0.8; }

  .stp-overlay-links {
    display: flex;
    gap: 20px;
    align-items: center;
  }
  .stp-overlay-links a {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
    border-bottom: 1px solid rgba(255,255,255,0.5);
    padding-bottom: 1px;
  }
  .stp-overlay-links a:hover { border-bottom-color: #fff; }

  /* ── Hotspot zones ── */
  .stp-hotspot-zone {
    position: absolute;
    width: 80px;
    height: 80px;
    transform: translate(-50%, -50%);
    cursor: pointer;
    z-index: 20;
    text-decoration: none;
    -webkit-tap-highlight-color: rgba(212,2,29,0.2);
  }
  .stp-hotspot-zone::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 22px; height: 22px;
    background: #d4021d;
    border: 3px solid #fff;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: transform 0.15s, background 0.15s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.35);
  }
  .stp-hotspot-zone::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 22px; height: 22px;
    border: 2px solid #d4021d;
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.7;
    animation: stp-ripple 2s ease-out infinite;
  }
  @keyframes stp-ripple {
    0%   { transform: translate(-50%,-50%) scale(1);   opacity: 0.7; }
    100% { transform: translate(-50%,-50%) scale(2.8); opacity: 0; }
  }
  .stp-hotspot-zone:hover::before,
  .stp-hotspot-zone:focus::before {
    transform: translate(-50%, -50%) scale(1.3);
    background: #a80118;
  }
  .stp-hotspot-zone:hover::after,
  .stp-hotspot-zone:focus::after { animation: none; opacity: 0; }

  /* Hover label */
  .stp-hotspot-label {
    position: absolute;
    bottom: calc(50% + 18px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    background: #000;
    color: #fff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 5px 9px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s, transform 0.15s;
    z-index: 30;
  }
  .stp-hotspot-label span { color: #aaa; margin-left: 6px; font-weight: 400; }
  .stp-hotspot-label::after {
    content: '';
    position: absolute;
    top: 100%; left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: #000;
  }
  .stp-hotspot-zone:hover .stp-hotspot-label,
  .stp-hotspot-zone:focus .stp-hotspot-label { opacity: 1; transform: translateX(-50%) translateY(0); }

  /* ── Product grid ── */
  .stp-grid-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 28px 24px 12px;
    border-top: 1px solid #e8e8e8;
  }
  .stp-grid-header h3 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #000;
    margin: 0;
  }
  .stp-grid-links { display: flex; gap: 20px; align-items: center; }
  .stp-grid-links a {
    font-size: 11px;
    color: #000;
    text-decoration: underline;
    letter-spacing: 0.04em;
  }
  .stp-product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0;
    padding: 0 24px;
  }
  .stp-product-card {
    padding: 12px 8px;
    text-decoration: none;
    display: block;
    border-right: 1px solid #e8e8e8;
    transition: background 0.1s;
  }
  .stp-product-card:last-child { border-right: none; }
  .stp-product-card:hover { background: #f7f7f7; }
  .stp-product-card img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
    background: #f5f5f5;
    margin-bottom: 8px;
  }
  .stp-product-card-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #000;
    margin: 0 0 3px;
    line-height: 1.3;
  }
  .stp-product-card-price { font-size: 10px; color: #000; }

  @media (max-width: 600px) {
    .stp-photo-wrapper { height: 100svh; }
    .stp-hotspot-zone { width: 64px; height: 64px; }
    .stp-hotspot-zone::before { width: 18px; height: 18px; }
    .stp-product-grid { grid-template-columns: repeat(2, 1fr); }
    .stp-overlay-bar { padding: 16px 16px; }
  }
</style>

<section class="stp-section">

  {%- if hero_url != blank -%}
    <div class="stp-photo-wrapper" id="stp-wrapper">

      {%- comment -%} Full-bleed hero image {%- endcomment -%}
      <img class="stp-hero" src="{{ hero_url }}" alt="{{ drop_title }}" loading="eager">

      {%- comment -%} Overlay: drop title + nav links {%- endcomment -%}
      <div class="stp-overlay-bar">
        <a class="stp-overlay-title" href="{{ drop_url }}">{{ drop_title }}</a>
        <div class="stp-overlay-links">
          <a href="/pages/drops">View all drops</a>
          <a href="/collections/all">Shop all</a>
        </div>
      </div>

      {%- comment -%} Hotspot data {%- endcomment -%}
      {%- if hotspots_data != blank -%}
        <script id="stp-hotspots-data" type="application/json">{{ hotspots_data | json }}</script>
      {%- endif -%}

    </div>
  {%- endif -%}

  {%- comment -%} Product grid below hero {%- endcomment -%}
  {%- if latest_drop and latest_drop.products_count > 0 -%}
    <div class="stp-grid-header">
      <h3>{{ drop_title }}</h3>
      <div class="stp-grid-links">
        <a href="/pages/drops">View all drops</a>
        <a href="/collections/all">Shop all</a>
      </div>
    </div>
    <div class="stp-product-grid">
      {%- for product in latest_drop.products -%}
        <a href="{{ product.url }}" class="stp-product-card">
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" loading="lazy">
          {%- endif -%}
          <p class="stp-product-card-title">{{ product.title }}</p>
          <p class="stp-product-card-price">{{ product.price | money }}</p>
        </a>
      {%- endfor -%}
    </div>
  {%- endif -%}

</section>

<script>
(function() {
  var wrapper = document.getElementById('stp-wrapper');
  var dataEl  = document.getElementById('stp-hotspots-data');
  if (!wrapper || !dataEl) return;

  var hotspots;
  try { hotspots = JSON.parse(dataEl.textContent.trim()); }
  catch(e) { console.warn('Overflow: hotspot parse error', e); return; }
  if (!Array.isArray(hotspots) || hotspots.length === 0) return;

  hotspots.forEach(function(hs) {
    var zone = document.createElement('a');
    zone.className  = 'stp-hotspot-zone';
    zone.href       = '/products/' + hs.handle;
    zone.style.left = hs.left + '%';
    zone.style.top  = hs.top  + '%';
    zone.setAttribute('aria-label', hs.title + ' — ' + hs.price);

    var label = document.createElement('span');
    label.className = 'stp-hotspot-label';
    label.innerHTML = hs.title + '<span>' + hs.price + '</span>';
    zone.appendChild(label);
    wrapper.appendChild(zone);
  });
})();
</script>

{% schema %}
{
  "name": "Shop the Photo",
  "tag": "section",
  "class": "section-shop-the-photo",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Fallback heading",
      "default": "Shop the photo",
      "info": "Only shown if no drop collections exist yet."
    },
    {
      "type": "url",
      "id": "photo_url",
      "label": "Fallback photo URL",
      "info": "Only used if no drop collections exist."
    }
  ],
  "presets": [{"name": "Shop the Photo"}]
}
{% endschema %}
