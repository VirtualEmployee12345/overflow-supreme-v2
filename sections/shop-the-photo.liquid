{% comment %}
  shop-the-photo.liquid
  Interactive "shop the photo" section.
  - Full-width hero image with clickable hotspot dots
  - Hover over dot → product card popup (image, title, price, link)
  - Product grid displayed below the photo
  - Section settings allow customizing heading + photo URL
{% endcomment %}

<style>
  .stp-section {
    background: #fff;
    padding: 0 0 60px 0;
    font-family: Arial, Helvetica, sans-serif;
  }

  /* ---- Header ---- */
  .stp-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 32px 24px 16px;
    border-bottom: 1px solid #e8e8e8;
    margin-bottom: 0;
  }
  .stp-header h2 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #000;
    margin: 0;
  }
  .stp-header a {
    font-size: 11px;
    color: #000;
    text-decoration: underline;
    letter-spacing: 0.04em;
  }
  .stp-header-links {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  /* ---- Photo Wrapper ---- */
  .stp-photo-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    cursor: crosshair;
    background: #111;
  }

  .stp-photo-wrapper img.stp-hero {
    width: 100%;
    height: auto;
    display: block;
    max-height: 80vh;
    object-fit: cover;
    object-position: center;
  }

  /* ---- Hotspot Dots ---- */
  .stp-hotspot {
    position: absolute;
    width: 20px;
    height: 20px;
    background: #fff;
    border: 2px solid #d4021d;
    border-radius: 50%;
    cursor: pointer;
    transform: translate(-50%, -50%);
    z-index: 10;
    transition: background 0.15s, transform 0.15s;
  }
  .stp-hotspot::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 8px;
    height: 8px;
    background: #d4021d;
    border-radius: 50%;
    transform: translate(-50%, -50%);
  }
  .stp-hotspot:hover,
  .stp-hotspot.active {
    background: #d4021d;
    transform: translate(-50%, -50%) scale(1.25);
  }
  .stp-hotspot:hover::after,
  .stp-hotspot.active::after {
    background: #fff;
  }

  /* Pulse animation for hotspots */
  @keyframes stp-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(212, 2, 29, 0.5); }
    70%  { box-shadow: 0 0 0 8px rgba(212, 2, 29, 0); }
    100% { box-shadow: 0 0 0 0 rgba(212, 2, 29, 0); }
  }
  .stp-hotspot {
    animation: stp-pulse 2s ease-in-out infinite;
  }
  .stp-hotspot:hover,
  .stp-hotspot.active {
    animation: none;
  }

  /* ---- Popup Card ---- */
  .stp-popup {
    position: absolute;
    width: 180px;
    background: #fff;
    border: 1px solid #e0e0e0;
    padding: 10px;
    z-index: 100;
    pointer-events: none;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.18s ease, transform 0.18s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
  }
  .stp-popup.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  /* Flip popup above dot if near bottom */
  .stp-popup.flip-up {
    transform: translateY(-100%) translateY(-24px);
  }
  .stp-popup.flip-up.visible {
    transform: translateY(-100%) translateY(-24px);
  }

  .stp-popup img {
    width: 100%;
    height: 110px;
    object-fit: cover;
    display: block;
    margin-bottom: 8px;
    background: #f5f5f5;
  }
  .stp-popup-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #000;
    margin: 0 0 3px;
    line-height: 1.3;
  }
  .stp-popup-price {
    font-size: 11px;
    color: #000;
    margin: 0 0 8px;
  }
  .stp-popup-link {
    display: block;
    background: #d4021d;
    color: #fff;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-align: center;
    text-decoration: none;
    padding: 6px 0;
  }
  .stp-popup-link:hover {
    background: #a80118;
    color: #fff;
    text-decoration: none;
  }

  /* ---- Product Grid Below Photo ---- */
  .stp-grid-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 28px 24px 12px;
    border-top: 1px solid #e8e8e8;
  }
  .stp-grid-header h3 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #000;
    margin: 0;
  }
  .stp-grid-header a {
    font-size: 11px;
    color: #000;
    text-decoration: underline;
    letter-spacing: 0.04em;
  }

  .stp-product-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0;
    padding: 0 24px;
  }
  @media (max-width: 900px) {
    .stp-product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 600px) {
    .stp-product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .stp-photo-wrapper img.stp-hero {
      max-height: 55vw;
    }
    .stp-hotspot {
      width: 14px;
      height: 14px;
    }
  }

  .stp-product-card {
    padding: 12px 8px;
    text-decoration: none;
    display: block;
    border-right: 1px solid #e8e8e8;
    transition: background 0.1s;
  }
  .stp-product-card:last-child {
    border-right: none;
  }
  .stp-product-card:hover {
    background: #f7f7f7;
  }
  .stp-product-card img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
    background: #f5f5f5;
    margin-bottom: 8px;
  }
  .stp-product-card-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #000;
    margin: 0 0 3px;
    line-height: 1.3;
  }
  .stp-product-card-price {
    font-size: 10px;
    color: #000;
  }
</style>

<section class="stp-section" data-section-id="{{ section.id }}" data-section-type="shop-the-photo">

  {% if section.settings.heading != blank %}
  <div class="stp-header">
    <h2>{{ section.settings.heading }}</h2>
    <div class="stp-header-links">
      <a href="/pages/drops">All drops</a>
      <a href="/collections/all">Shop all</a>
    </div>
  </div>
  {% endif %}

  {%- comment -%} Photo with hotspots {%- endcomment -%}
  <div class="stp-photo-wrapper" id="stp-wrapper-{{ section.id }}">
    <img
      class="stp-hero"
      src="{{ section.settings.photo_url | default: 'https://cdn.shopify.com/s/files/1/0648/8988/0637/files/IMG_8292.jpg?v=1773951570' }}"
      alt="{{ section.settings.heading | default: 'Shop the photo' }}"
      loading="eager"
      id="stp-hero-img-{{ section.id }}"
    >

    {%- comment -%} Hotspots — positions are in percentages of image natural dimensions (1920×1080) {%- endcomment -%}
    {%- assign hotspots = "" -%}

    {% comment %} Each hotspot: left% | top% | handle | title | price | image_url {% endcomment %}

    {%- assign h1 = "22.4|48.1|nikon-fa-35mm-film-camera|Nikon FA 35mm Film Camera|$285" -%}
    {%- assign h2 = "45.3|39.8|sony-digital-mirrorless-camera|Sony Mirrorless Digital Camera|$495" -%}
    {%- assign h3 = "68.2|24.1|galax-pro-cordless-drill|Galax Pro Cordless Drill|$49" -%}
    {%- assign h4 = "41.1|61.1|thermopro-digital-thermometer|ThermoPro Thermometer|$18" -%}
    {%- assign h5 = "60.1|55.6|glass-salt-shaker|Glass Salt Shaker|$8" -%}
    {%- assign h6 = "30.7|73.1|stanley-tape-measure|Stanley Tape Measure 25ft|$14" -%}
    {%- assign all_hotspots = h1 | append: "||" | append: h2 | append: "||" | append: h3 | append: "||" | append: h4 | append: "||" | append: h5 | append: "||" | append: h6 -%}
    {%- assign hotspot_list = all_hotspots | split: "||" -%}

    {% for hs in hotspot_list %}
      {%- assign hs_parts = hs | split: "|" -%}
      {%- assign hs_left = hs_parts[0] -%}
      {%- assign hs_top  = hs_parts[1] -%}
      {%- assign hs_handle = hs_parts[2] -%}
      {%- assign hs_title  = hs_parts[3] -%}
      {%- assign hs_price  = hs_parts[4] -%}
      {%- assign forloop_index = forloop.index -%}

      <button
        class="stp-hotspot"
        style="left: {{ hs_left }}%; top: {{ hs_top }}%;"
        data-handle="{{ hs_handle }}"
        data-popup="stp-popup-{{ section.id }}-{{ forloop_index }}"
        aria-label="View {{ hs_title }}"
        type="button"
      ></button>

      <div
        class="stp-popup"
        id="stp-popup-{{ section.id }}-{{ forloop_index }}"
        style="left: {{ hs_left }}%; top: {{ hs_top }}%;"
        role="tooltip"
        aria-hidden="true"
      >
        {%- assign prod = all_products[hs_handle] -%}
        {%- comment -%}
          Hardcode the image URLs since Liquid can't dynamically look up products by handle
          without an assign or forloop. We use the known CDN URLs from product creation.
        {%- endcomment -%}
        {%- if hs_handle == "nikon-fa-35mm-film-camera" -%}
          {%- assign popup_img = "https://cdn.shopify.com/s/files/1/0648/8988/0637/files/ccdee2d155b005c0e8fc2a6a0cef578a.jpg?v=1773950551" -%}
        {%- elsif hs_handle == "sony-digital-mirrorless-camera" -%}
          {%- assign popup_img = "https://cdn.shopify.com/s/files/1/0648/8988/0637/files/8f5afb38e935ce8c11cbae889e9c5141.jpg?v=1773950553" -%}
        {%- elsif hs_handle == "galax-pro-cordless-drill" -%}
          {%- assign popup_img = "https://cdn.shopify.com/s/files/1/0648/8988/0637/files/93b5ca4e75bb50e9e36d0f153919463d.jpg?v=1773950555" -%}
        {%- elsif hs_handle == "thermopro-digital-thermometer" -%}
          {%- assign popup_img = "https://cdn.shopify.com/s/files/1/0648/8988/0637/files/6e89e3b5525992621f575bf6c708903d.jpg?v=1773950557" -%}
        {%- elsif hs_handle == "glass-salt-shaker" -%}
          {%- assign popup_img = "https://cdn.shopify.com/s/files/1/0648/8988/0637/files/b0d1f7240e959ea0b6da175edee2bfe5.jpg?v=1773950560" -%}
        {%- elsif hs_handle == "stanley-tape-measure" -%}
          {%- assign popup_img = "https://cdn.shopify.com/s/files/1/0648/8988/0637/files/4ca44f1f3cf75da8885c0744c2f600ea.jpg?v=1773950562" -%}
        {%- else -%}
          {%- assign popup_img = "" -%}
        {%- endif -%}

        {% if popup_img != "" %}
          <img src="{{ popup_img }}" alt="{{ hs_title }}" loading="lazy">
        {% endif %}
        <p class="stp-popup-title">{{ hs_title }}</p>
        <p class="stp-popup-price">{{ hs_price }}</p>
        <a class="stp-popup-link" href="/products/{{ hs_handle }}">View product</a>
      </div>
    {% endfor %}
  </div>

  {%- comment -%} Product grid below {%- endcomment -%}
  <div class="stp-grid-header">
    <h3>Shop the photo</h3>
    <a href="/collections/all">View all</a>
  </div>

  <div class="stp-product-grid">
    {%- assign grid_products = "nikon-fa-35mm-film-camera,sony-digital-mirrorless-camera,galax-pro-cordless-drill,thermopro-digital-thermometer,glass-salt-shaker,stanley-tape-measure" | split: "," -%}

    {%- for gp_handle in grid_products -%}
      {%- if gp_handle == "nikon-fa-35mm-film-camera" -%}
        {%- assign gp_img   = "https://cdn.shopify.com/s/files/1/0648/8988/0637/files/ccdee2d155b005c0e8fc2a6a0cef578a.jpg?v=1773950551" -%}
        {%- assign gp_title = "Nikon FA 35mm" -%}
        {%- assign gp_price = "$285" -%}
      {%- elsif gp_handle == "sony-digital-mirrorless-camera" -%}
        {%- assign gp_img   = "https://cdn.shopify.com/s/files/1/0648/8988/0637/files/8f5afb38e935ce8c11cbae889e9c5141.jpg?v=1773950553" -%}
        {%- assign gp_title = "Sony Mirrorless" -%}
        {%- assign gp_price = "$495" -%}
      {%- elsif gp_handle == "galax-pro-cordless-drill" -%}
        {%- assign gp_img   = "https://cdn.shopify.com/s/files/1/0648/8988/0637/files/93b5ca4e75bb50e9e36d0f153919463d.jpg?v=1773950555" -%}
        {%- assign gp_title = "Galax Pro Drill" -%}
        {%- assign gp_price = "$49" -%}
      {%- elsif gp_handle == "thermopro-digital-thermometer" -%}
        {%- assign gp_img   = "https://cdn.shopify.com/s/files/1/0648/8988/0637/files/6e89e3b5525992621f575bf6c708903d.jpg?v=1773950557" -%}
        {%- assign gp_title = "ThermoPro Hygrometer" -%}
        {%- assign gp_price = "$18" -%}
      {%- elsif gp_handle == "glass-salt-shaker" -%}
        {%- assign gp_img   = "https://cdn.shopify.com/s/files/1/0648/8988/0637/files/b0d1f7240e959ea0b6da175edee2bfe5.jpg?v=1773950560" -%}
        {%- assign gp_title = "Glass Salt Shaker" -%}
        {%- assign gp_price = "$8" -%}
      {%- elsif gp_handle == "stanley-tape-measure" -%}
        {%- assign gp_img   = "https://cdn.shopify.com/s/files/1/0648/8988/0637/files/4ca44f1f3cf75da8885c0744c2f600ea.jpg?v=1773950562" -%}
        {%- assign gp_title = "Stanley Tape Measure" -%}
        {%- assign gp_price = "$14" -%}
      {%- endif -%}
      <a href="/products/{{ gp_handle }}" class="stp-product-card">
        <img src="{{ gp_img }}" alt="{{ gp_title }}" loading="lazy">
        <p class="stp-product-card-title">{{ gp_title }}</p>
        <p class="stp-product-card-price">{{ gp_price }}</p>
      </a>
    {%- endfor -%}
  </div>
</section>

<script>
(function() {
  var wrapperEl = document.getElementById('stp-wrapper-{{ section.id }}');
  if (!wrapperEl) return;

  var hotspots = wrapperEl.querySelectorAll('.stp-hotspot');
  var activePopup = null;
  var activeHotspot = null;

  function showPopup(hotspot) {
    hideAll();
    var popupId = hotspot.getAttribute('data-popup');
    var popup = document.getElementById(popupId);
    if (!popup) return;

    // Reposition popup relative to hotspot
    var wrapperRect = wrapperEl.getBoundingClientRect();
    var hotspotRect = hotspot.getBoundingClientRect();

    var leftPx = hotspotRect.left - wrapperRect.left + 14;
    var topPx  = hotspotRect.top  - wrapperRect.top  + 14;

    // Flip left if popup would overflow right edge
    var popupWidth = 180;
    if (leftPx + popupWidth > wrapperRect.width - 10) {
      leftPx = hotspotRect.left - wrapperRect.left - popupWidth - 6;
    }

    // Flip up if popup would overflow bottom
    var popupHeight = 210;
    if (topPx + popupHeight > wrapperRect.height - 10) {
      topPx = hotspotRect.top - wrapperRect.top - popupHeight - 6;
      popup.classList.add('flip-up');
    } else {
      popup.classList.remove('flip-up');
    }

    popup.style.left = leftPx + 'px';
    popup.style.top  = topPx + 'px';
    popup.style.transform = '';
    popup.classList.add('visible');
    popup.removeAttribute('aria-hidden');

    hotspot.classList.add('active');
    activePopup = popup;
    activeHotspot = hotspot;
  }

  function hideAll() {
    var allPopups = wrapperEl.querySelectorAll('.stp-popup');
    allPopups.forEach(function(p) {
      p.classList.remove('visible', 'flip-up');
      p.setAttribute('aria-hidden', 'true');
    });
    hotspots.forEach(function(h) { h.classList.remove('active'); });
    activePopup = null;
    activeHotspot = null;
  }

  hotspots.forEach(function(hotspot) {
    // Mouse enter shows popup
    hotspot.addEventListener('mouseenter', function() { showPopup(hotspot); });

    // Click toggles popup (mobile support)
    hotspot.addEventListener('click', function(e) {
      e.stopPropagation();
      if (hotspot.classList.contains('active')) {
        hideAll();
      } else {
        showPopup(hotspot);
      }
    });
  });

  // Keep popup visible when cursor moves into it
  wrapperEl.addEventListener('mouseover', function(e) {
    if (!e.target.closest('.stp-popup') && !e.target.closest('.stp-hotspot')) {
      // Small delay so cursor can travel to popup
    }
  });

  // Hide when clicking outside
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.stp-hotspot') && !e.target.closest('.stp-popup')) {
      hideAll();
    }
  });

  // Keep popups working if image resizes
  window.addEventListener('resize', hideAll);
})();
</script>

{% schema %}
{
  "name": "Shop the Photo",
  "tag": "section",
  "class": "section-shop-the-photo",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop the photo"
    },
    {
      "type": "url",
      "id": "photo_url",
      "label": "Hero photo URL",
      "info": "CDN URL of the source photo. Upload via Shopify Admin → Content → Files."
    }
  ],
  "presets": [
    {
      "name": "Shop the Photo"
    }
  ]
}
{% endschema %}
