{% comment %}
  back-to-drop.liquid — v2
  Slim top bar on every product page:
  - LEFT: ← back link (drop name / shop)
  - RIGHT: RANDOM > button (goes to random drop collection)
{% endcomment %}

{%- comment -%} Gather all drop handles for the random button {%- endcomment -%}
{%- assign drop_handles_str = '' -%}
{%- assign dcount = 0 -%}
{%- for col in collections -%}
  {%- if col.handle contains 'drop-' -%}
    {%- assign hero = col.metafields.custom.hero_photo_url.value -%}
    {%- if hero != blank -%}
      {%- if dcount > 0 -%}
        {%- assign drop_handles_str = drop_handles_str | append: ',' -%}
      {%- endif -%}
      {%- assign drop_handles_str = drop_handles_str | append: col.handle -%}
      {%- assign dcount = dcount | plus: 1 -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

<style>
  .back-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    height: 36px;
    border-bottom: 1px solid #e8e8e8;
    background: #fff;
    position: relative;
    z-index: 10;
  }

  .back-bar__link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: 'Courier New', Courier, monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    color: #000;
    text-decoration: none;
    line-height: 1;
    transition: color 0.12s;
  }

  .back-bar__link:hover {
    color: #d4021d;
  }

  /* Arrow SVG */
  .back-bar__arrow {
    display: block;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    transition: transform 0.12s;
  }

  .back-bar__link:hover .back-bar__arrow {
    transform: translateX(-3px);
  }

  /* RANDOM > button on right */
  .back-bar__random {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: 'Courier New', Courier, monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    color: #000;
    text-decoration: none;
    line-height: 1;
    transition: color 0.12s;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }
  .back-bar__random:hover {
    color: #d4021d;
  }
  .back-bar__random svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    transition: transform 0.12s;
  }
  .back-bar__random:hover svg {
    transform: translateX(3px);
  }

  @media (max-width: 749px) {
    .back-bar {
      padding: 0 16px;
    }
  }
</style>

<div class="back-bar" id="back-bar">
  <a class="back-bar__link" href="/" id="back-bar-link" aria-label="Go back">
    <svg class="back-bar__arrow" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M9 2L4 7L9 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span id="back-bar-label">shop</span>
  </a>

  {%- if dcount > 0 -%}
    <button class="back-bar__random" id="back-bar-random" aria-label="Go to a random drop">
      <span>random</span>
      <svg viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M5 2L10 7L5 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  {%- endif -%}
</div>

<script>
(function() {
  /* ── Back link logic ── */
  var SESSION_KEY = 'overflow_back_url';
  var LABEL_KEY   = 'overflow_back_label';

  var linkEl  = document.getElementById('back-bar-link');
  var labelEl = document.getElementById('back-bar-label');

  if (linkEl && labelEl) {
    function labelFromUrl(url) {
      try {
        var path = new URL(url).pathname;
        var parts = path.split('/').filter(Boolean);
        if (parts[0] === 'collections' && parts[1]) {
          return parts[1].replace(/-/g, ' ');
        }
        if (parts[0] === 'pages' && parts[1]) {
          return parts[1].replace(/-/g, ' ');
        }
        return 'shop';
      } catch(e) {
        return 'shop';
      }
    }

    function isSameOrigin(url) {
      try {
        return new URL(url).hostname === window.location.hostname;
      } catch(e) { return false; }
    }

    var backUrl   = '/';
    var backLabel = 'shop';
    var ref = document.referrer;

    if (ref && isSameOrigin(ref) && !ref.includes('/products/')) {
      backUrl   = ref;
      backLabel = labelFromUrl(ref);
      try {
        sessionStorage.setItem(SESSION_KEY, backUrl);
        sessionStorage.setItem(LABEL_KEY,   backLabel);
      } catch(e) {}
    } else {
      try {
        var stored      = sessionStorage.getItem(SESSION_KEY);
        var storedLabel = sessionStorage.getItem(LABEL_KEY);
        if (stored && storedLabel) {
          backUrl   = stored;
          backLabel = storedLabel;
        }
      } catch(e) {}
    }

    linkEl.href         = backUrl;
    labelEl.textContent = backLabel;
  }

  /* ── RANDOM button logic ── */
  var randomBtn = document.getElementById('back-bar-random');
  if (randomBtn) {
    var handles = {{ drop_handles_str | split: ',' | json }};
    randomBtn.addEventListener('click', function() {
      if (handles.length > 0) {
        var idx = Math.floor(Math.random() * handles.length);
        window.location.href = '/collections/' + handles[idx];
      }
    });
  }
})();
</script>

{% schema %}
{
  "name": "Back to Drop",
  "tag": "section",
  "class": "section-back-bar",
  "settings": [],
  "presets": [{"name": "Back to Drop"}]
}
{% endschema %}
