{{ 'section-footer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer { margin-top: 0; }
{%- endstyle -%}

<footer class="footer footer-brutalist color-{{ section.settings.color_scheme }} gradient">
  <div class="footer-brutalist__inner">
    <div class="footer-brutalist__primary">
      <a href="/collections/all" class="footer-brutalist__link">shop</a>
      <a href="/collections/all" class="footer-brutalist__link footer-brutalist__link--active">view all</a>
    </div>

    <div class="footer-brutalist__secondary">
      <a href="/pages/spring-summer-preview" class="footer-brutalist__link">spring/summer {{ 'now' | date: '%Y' }} preview</a>
      <a href="/pages/lookbook" class="footer-brutalist__link">lookbook</a>
      <a href="/blogs/news" class="footer-brutalist__link">news</a>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "footer-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Section top margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Section top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Section bottom padding",
      "default": 0
    }
  ],
  "blocks": [
    { "type": "@app" }
  ]
}
{% endschema %}
