{% comment %}
  product-hotspot-hero.liquid
  "You May Also Like" section for product pages.
  Shows the hero photo with hotspots from the product's parent drop collection.

  How it works:
  1. Iterates product.collections to find the drop-* collection
  2. Reads custom.hero_photo_url and custom.hotspots metafields
  3. Renders a full-bleed hero with pulsing hotspot dots
{% endcomment %}

{%- assign drop_collection = nil -%}
{%- for col in product.collections -%}
  {%- if col.handle contains 'drop-' -%}
    {%- assign drop_collection = col -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- if drop_collection -%}
  {%- assign hero_url = drop_collection.metafields.custom.hero_photo_url.value -%}
  {%- assign hotspots_data = drop_collection.metafields.custom.hotspots.value -%}
{%- endif -%}

<style>
  /* ── "You May Also Like" heading ── */
  .phs-heading {
    font-family: Arial, Helvetica, "Helvetica Neue", sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: #000;
    margin: 0;
    padding: 32px 24px 16px;
    text-align: left;
  }

  /* ── Full-bleed hero wrapper ── */
  .phs-photo-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #111;
    display: block;
  }

  /* Image fills width, natural aspect ratio */
  .phs-hero {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  /* ── Hotspot zones ── */
  .phs-hotspot-zone {
    position: absolute;
    width: 80px;
    height: 80px;
    transform: translate(-50%, -50%);
    cursor: pointer;
    z-index: 20;
    text-decoration: none;
    -webkit-tap-highlight-color: rgba(212,2,29,0.2);
  }
  .phs-hotspot-zone::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 22px; height: 22px;
    background: #d4021d;
    border: 3px solid #fff;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: transform 0.15s, background 0.15s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.35);
  }
  .phs-hotspot-zone::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 22px; height: 22px;
    border: 2px solid #d4021d;
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.7;
    animation: phs-ripple 2s ease-out infinite;
  }
  @keyframes phs-ripple {
    0%   { transform: translate(-50%,-50%) scale(1);   opacity: 0.7; }
    100% { transform: translate(-50%,-50%) scale(2.8); opacity: 0; }
  }
  .phs-hotspot-zone:hover::before,
  .phs-hotspot-zone:focus::before {
    transform: translate(-50%, -50%) scale(1.3);
    background: #a80118;
  }
  .phs-hotspot-zone:hover::after,
  .phs-hotspot-zone:focus::after { animation: none; opacity: 0; }

  /* Highlight current product's hotspot */
  .phs-hotspot-zone--current::before {
    background: #fff;
    border-color: #d4021d;
  }
  .phs-hotspot-zone--current::after {
    border-color: #fff;
  }

  /* Hover label */
  .phs-hotspot-label {
    position: absolute;
    bottom: calc(50% + 18px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    background: #000;
    color: #fff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 5px 9px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s, transform 0.15s;
    z-index: 30;
  }
  .phs-hotspot-label span { color: #aaa; margin-left: 6px; font-weight: 400; }
  .phs-hotspot-label::after {
    content: '';
    position: absolute;
    top: 100%; left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: #000;
  }
  .phs-hotspot-zone:hover .phs-hotspot-label,
  .phs-hotspot-zone:focus .phs-hotspot-label { opacity: 1; transform: translateX(-50%) translateY(0); }

  @media (max-width: 600px) {
    .phs-heading {
      padding: 24px 16px 12px;
    }
    .phs-hotspot-zone { width: 64px; height: 64px; }
    .phs-hotspot-zone::before { width: 18px; height: 18px; }
  }
</style>

{%- if hero_url != blank -%}
  <section class="phs-section">
    <h2 class="phs-heading">You may also like</h2>

    <div class="phs-photo-wrapper" id="phs-wrapper">
      <img class="phs-hero" src="{{ hero_url }}" alt="{{ drop_collection.title | escape }}" loading="lazy">

      {%- if hotspots_data != blank -%}
        <script id="phs-hotspots-data" type="application/json">{{ hotspots_data | json }}</script>
      {%- endif -%}
    </div>
  </section>

  <script>
  /* Product page hotspots */
  (function() {
    var wrapper = document.getElementById('phs-wrapper');
    var dataEl  = document.getElementById('phs-hotspots-data');
    if (!wrapper || !dataEl) return;

    var hotspots;
    try { hotspots = JSON.parse(dataEl.textContent.trim()); }
    catch(e) { console.warn('Overflow: hotspot parse error', e); return; }
    if (!Array.isArray(hotspots) || hotspots.length === 0) return;

    var currentHandle = {{ product.handle | json }};

    hotspots.forEach(function(hs) {
      var zone = document.createElement('a');
      zone.className = 'phs-hotspot-zone';
      if (hs.handle === currentHandle) {
        zone.className += ' phs-hotspot-zone--current';
      }
      zone.href       = '/products/' + hs.handle;
      zone.style.left = hs.left + '%';
      zone.style.top  = hs.top  + '%';
      zone.setAttribute('aria-label', hs.title + ' — ' + hs.price);

      var label = document.createElement('span');
      label.className = 'phs-hotspot-label';
      label.innerHTML = hs.title + '<span>' + hs.price + '</span>';
      zone.appendChild(label);
      wrapper.appendChild(zone);
    });
  })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Product Hotspot Hero",
  "tag": "section",
  "class": "section-product-hotspot-hero",
  "settings": [],
  "templates": ["product"],
  "presets": [{"name": "Product Hotspot Hero"}]
}
{% endschema %}
