{% comment %}
  product-hotspot-hero.liquid — v2
  Shows ALL drop-collection hero photos with hotspots,
  shuffled into a random order on every page load.
  Also includes a "RANDOM >" button in the top-right that
  navigates to a random drop collection page.
{% endcomment %}

{%- comment -%} ── Gather all drop collections with hero photos ── {%- endcomment -%}
{%- assign drop_handles = '' -%}
{%- assign drop_count = 0 -%}
{%- for col in collections -%}
  {%- assign h = col.handle -%}
  {%- if h contains 'drop-' -%}
    {%- assign hero = col.metafields.custom.hero_photo_url.value -%}
    {%- if hero != blank -%}
      {%- if drop_count > 0 -%}
        {%- assign drop_handles = drop_handles | append: '|||' -%}
      {%- endif -%}
      {%- assign drop_handles = drop_handles | append: h -%}
      {%- assign drop_count = drop_count | plus: 1 -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

<style>
  /* ── "You May Also Like" heading ── */
  .phs-heading {
    font-family: Arial, Helvetica, "Helvetica Neue", sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: #000;
    margin: 0;
    padding: 32px 24px 16px;
    text-align: left;
    position: relative;
  }

  /* ── RANDOM > button ── */
  .phs-random-btn {
    position: absolute;
    right: 24px;
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: #000;
    text-decoration: none;
    line-height: 1;
    transition: color 0.12s;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }
  .phs-random-btn:hover {
    color: #d4021d;
  }
  .phs-random-btn svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    transition: transform 0.12s;
  }
  .phs-random-btn:hover svg {
    transform: translateX(3px);
  }

  /* ── Full-bleed hero wrapper ── */
  .phs-photo-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #f5f5f5;
    display: block;
    margin-bottom: 2px;
  }

  /* Image fills width, natural aspect ratio */
  .phs-hero {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  /* ── Hotspot zones ── */
  .phs-hotspot-zone {
    position: absolute;
    width: 80px;
    height: 80px;
    transform: translate(-50%, -50%);
    cursor: pointer;
    z-index: 20;
    text-decoration: none;
    -webkit-tap-highlight-color: rgba(212,2,29,0.2);
  }
  .phs-hotspot-zone::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 22px; height: 22px;
    background: #d4021d;
    border: 3px solid #fff;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: transform 0.15s, background 0.15s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.35);
  }
  .phs-hotspot-zone::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 22px; height: 22px;
    border: 2px solid #d4021d;
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.7;
    animation: phs-ripple 2s ease-out infinite;
  }
  @keyframes phs-ripple {
    0%   { transform: translate(-50%,-50%) scale(1);   opacity: 0.7; }
    100% { transform: translate(-50%,-50%) scale(2.8); opacity: 0; }
  }
  .phs-hotspot-zone:hover::before,
  .phs-hotspot-zone:focus::before {
    transform: translate(-50%, -50%) scale(1.3);
    background: #a80118;
  }
  .phs-hotspot-zone:hover::after,
  .phs-hotspot-zone:focus::after { animation: none; opacity: 0; }

  /* Highlight current product's hotspot */
  .phs-hotspot-zone--current::before {
    background: #fff;
    border-color: #d4021d;
  }
  .phs-hotspot-zone--current::after {
    border-color: #fff;
  }

  /* Hover label */
  .phs-hotspot-label {
    position: absolute;
    bottom: calc(50% + 18px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    background: #000;
    color: #fff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 5px 9px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s, transform 0.15s;
    z-index: 30;
  }
  .phs-hotspot-label span { color: #aaa; margin-left: 6px; font-weight: 400; }
  .phs-hotspot-label::after {
    content: '';
    position: absolute;
    top: 100%; left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: #000;
  }
  .phs-hotspot-zone:hover .phs-hotspot-label,
  .phs-hotspot-zone:focus .phs-hotspot-label { opacity: 1; transform: translateX(-50%) translateY(0); }

  @media (max-width: 600px) {
    .phs-heading {
      padding: 24px 16px 12px;
    }
    .phs-random-btn {
      right: 16px;
    }
    .phs-hotspot-zone { width: 64px; height: 64px; }
    .phs-hotspot-zone::before { width: 18px; height: 18px; }
  }
</style>

{%- if drop_count > 0 -%}
  <section class="phs-section">
    <h2 class="phs-heading">
      You may also like
      <a class="phs-random-btn" id="phs-random-btn" href="/" aria-label="Go to a random drop">
        <span>random</span>
        <svg viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M5 2L10 7L5 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </h2>

    {%- comment -%} Render all drop hero photos — JS will shuffle them {%- endcomment -%}
    <div id="phs-all-drops">
      {%- assign drop_arr = drop_handles | split: '|||' -%}
      {%- for handle in drop_arr -%}
        {%- assign dcol = collections[handle] -%}
        {%- assign hero_url = dcol.metafields.custom.hero_photo_url.value -%}
        {%- assign hotspots_data = dcol.metafields.custom.hotspots.value -%}

        <div class="phs-drop-block" data-drop-handle="{{ handle }}" style="display:none;">
          <div class="phs-photo-wrapper">
            <img class="phs-hero" src="{{ hero_url }}" alt="{{ dcol.title | escape }}" loading="lazy">
            {%- if hotspots_data != blank -%}
              <script class="phs-hotspots-json" type="application/json">{{ hotspots_data | json }}</script>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </section>

  <script>
  (function() {
    /* ── Collect all drop blocks ── */
    var container = document.getElementById('phs-all-drops');
    if (!container) return;
    var blocks = Array.prototype.slice.call(container.querySelectorAll('.phs-drop-block'));
    if (blocks.length === 0) return;

    var currentHandle = {{ product.handle | json }};
    var currentProductDrop = null;

    /* ── Gather drop handles for RANDOM button ── */
    var dropHandles = [];
    blocks.forEach(function(b) {
      dropHandles.push(b.getAttribute('data-drop-handle'));
    });

    /* ── Find which drop contains the current product ── */
    {%- for col in product.collections -%}
      {%- if col.handle contains 'drop-' -%}
        currentProductDrop = {{ col.handle | json }};
      {%- endif -%}
    {%- endfor -%}

    /* ── Shuffle the blocks array (Fisher-Yates) ── */
    for (var i = blocks.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var temp = blocks[i];
      blocks[i] = blocks[j];
      blocks[j] = temp;
    }

    /* ── Move current product's drop to the front of the array ── */
    if (currentProductDrop) {
      for (var k = 0; k < blocks.length; k++) {
        if (blocks[k].getAttribute('data-drop-handle') === currentProductDrop) {
          var item = blocks.splice(k, 1)[0];
          blocks.unshift(item);
          break;
        }
      }
    }

    /* ── Re-append in shuffled order and show ── */
    blocks.forEach(function(block) {
      container.appendChild(block);
      block.style.display = '';

      var wrapper = block.querySelector('.phs-photo-wrapper');
      var dataEl  = block.querySelector('.phs-hotspots-json');
      if (!wrapper || !dataEl) return;

      var hotspots;
      try { hotspots = JSON.parse(dataEl.textContent.trim()); }
      catch(e) { return; }
      if (!Array.isArray(hotspots) || hotspots.length === 0) return;

      hotspots.forEach(function(hs) {
        var zone = document.createElement('a');
        zone.className = 'phs-hotspot-zone';
        if (hs.handle === currentHandle) {
          zone.className += ' phs-hotspot-zone--current';
        }
        zone.href       = '/products/' + hs.handle;
        zone.style.left = hs.left + '%';
        zone.style.top  = hs.top  + '%';
        zone.setAttribute('aria-label', hs.title + ' — ' + hs.price);

        var label = document.createElement('span');
        label.className = 'phs-hotspot-label';
        label.innerHTML = hs.title + '<span>' + hs.price + '</span>';
        zone.appendChild(label);
        wrapper.appendChild(zone);
      });
    });

    /* ── RANDOM button — go to a random drop collection ── */
    var randomBtn = document.getElementById('phs-random-btn');
    if (randomBtn && dropHandles.length > 0) {
      randomBtn.addEventListener('click', function(e) {
        e.preventDefault();
        var idx = Math.floor(Math.random() * dropHandles.length);
        window.location.href = '/collections/' + dropHandles[idx];
      });
    }
  })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Product Hotspot Hero",
  "tag": "section",
  "class": "section-product-hotspot-hero",
  "settings": [],
  "templates": ["product"],
  "presets": [{"name": "Product Hotspot Hero"}]
}
{% endschema %}
