{% comment %}
  drops-list.liquid

  Visual grid of all drop collections with thumbnail cards.
  - Each card shows the drop hero image, title, and item count
  - Newest drops appear first (reversed via JS)
  - Links use {{ col.url }} to always point to the real Shopify collection URL
  - New drops appear automatically as long as their handle starts with "drop-"

  Hero photos: collection metafield custom.hero_photo_url, fallback to collection.image
{% endcomment %}

<style>
  .drops-list-section {
    background: #fff;
    font-family: Arial, Helvetica, sans-serif;
    min-height: 60vh;
  }

  /* ── Page header ── */
  .drops-list-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 32px 24px 0;
    border-bottom: 2px solid #000;
    padding-bottom: 12px;
  }
  .drops-list-header h1 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #000;
    margin: 0;
  }
  .drops-list-header span {
    font-size: 10px;
    color: #888;
    letter-spacing: 0.06em;
  }

  /* ── Grid of drop cards ── */
  .drops-grid {
    list-style: none;
    margin: 0;
    padding: 24px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  @media (max-width: 900px) {
    .drops-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; padding: 16px; }
  }
  @media (max-width: 480px) {
    .drops-grid { grid-template-columns: 1fr; gap: 14px; padding: 14px; }
  }

  .drops-grid__card {
    position: relative;
  }

  .drops-grid__link {
    display: block;
    text-decoration: none;
    color: #000;
    border: 1px solid transparent;
    transition: border-color 0.15s;
  }
  .drops-grid__link:hover {
    border-color: #e0e0e0;
  }

  .drops-grid__image-wrap {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f5f5f5;
    position: relative;
  }
  .drops-grid__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* NEW badge for latest drop */
  .drops-grid__badge {
    position: absolute;
    top: 8px;
    left: 8px;
    background: #d4021d;
    color: #fff;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 7px;
    line-height: 1;
  }

  .drops-grid__info {
    padding: 10px 12px 12px;
  }
  .drops-grid__title {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 4px;
    line-height: 1.3;
    color: #000;
  }
  .drops-grid__meta {
    font-size: 10px;
    color: #888;
    letter-spacing: 0.04em;
  }

  .drops-grid__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: #bbb;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ── Empty state ── */
  .drops-list__empty {
    padding: 60px 24px;
    font-size: 11px;
    color: #888;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    list-style: none;
  }
</style>

<div class="drops-list-section">
  <div class="drops-list-header">
    <h1>All drops</h1>
    <span id="drops-list-count"></span>
  </div>

  {%- assign drop_count = 0 -%}

  <ul class="drops-grid" id="drops-list">
    {%- for col in collections -%}
      {%- if col.handle contains 'drop-' -%}
        {%- assign drop_count = drop_count | plus: 1 -%}
        {%- assign hero_url = col.metafields.custom.hero_photo_url.value -%}
        {%- if hero_url == blank and col.image -%}
          {%- assign hero_url = col.image | image_url: width: 800 -%}
        {%- endif -%}
        {%- assign first_product = col.products | first -%}
        <li class="drops-grid__card">
          <a class="drops-grid__link" href="{{ col.url }}">
            <div class="drops-grid__image-wrap">
              {%- if hero_url != blank -%}
                <img src="{{ hero_url }}" alt="{{ col.title | escape }}" loading="lazy" width="600" height="450">
              {%- elsif first_product and first_product.featured_media -%}
                <img src="{{ first_product.featured_media | image_url: width: 600 }}" alt="{{ col.title | escape }}" loading="lazy" width="600" height="450">
              {%- else -%}
                <div class="drops-grid__placeholder">No preview</div>
              {%- endif -%}
            </div>
            <div class="drops-grid__info">
              <p class="drops-grid__title">{{ col.title }}</p>
              <span class="drops-grid__meta">{{ col.products_count }} item{% if col.products_count != 1 %}s{% endif %}</span>
            </div>
          </a>
        </li>
      {%- endif -%}
    {%- endfor -%}

    {%- if drop_count == 0 -%}
      <li class="drops-list__empty">No drops yet — check back soon.</li>
    {%- endif -%}
  </ul>
</div>

<script>
(function() {
  var listEl = document.getElementById('drops-list');
  if (!listEl) return;

  // Reverse so newest drop cards appear first
  var items = Array.from(listEl.querySelectorAll('.drops-grid__card'));
  items.reverse().forEach(function(item) { listEl.appendChild(item); });

  // Add NEW badge to the first card (newest drop)
  var firstWrap = listEl.querySelector('.drops-grid__card .drops-grid__image-wrap');
  if (firstWrap) {
    var badge = document.createElement('span');
    badge.className = 'drops-grid__badge';
    badge.textContent = 'NEW';
    firstWrap.appendChild(badge);
  }

  // Update the count label
  var countEl = document.getElementById('drops-list-count');
  if (countEl) {
    var n = items.length;
    countEl.textContent = n + ' drop' + (n !== 1 ? 's' : '');
  }
})();
</script>

{% schema %}
{
  "name": "Drops List",
  "tag": "section",
  "class": "section-drops-list",
  "settings": [],
  "presets": [{"name": "Drops List"}]
}
{% endschema %}
