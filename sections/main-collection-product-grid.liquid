{{ 'template-collection.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* Supreme-style two-column layout: sidebar + grid */
  .supreme-collection-layout {
    display: grid;
    grid-template-columns: 130px 1fr;
    min-height: 60vh;
    background: #000;
  }

  @media screen and (max-width: 749px) {
    .supreme-collection-layout {
      grid-template-columns: 1fr;
    }
    .supreme-sidebar { display: none; }
  }

  /* ── Sidebar ── */
  .supreme-sidebar {
    padding: 18px 0 18px 20px;
    background: #000;
  }

  .supreme-sidebar__nav {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0;
  }

  .supreme-sidebar__link {
    font-family: Arial, Helvetica, "Helvetica Neue", sans-serif;
    font-size: 11px;
    font-weight: 400;
    color: #fff;
    text-decoration: none;
    text-align: right;
    display: block;
    padding: 2px 10px 2px 0;
    line-height: 1.7;
  }

  .supreme-sidebar__link:hover,
  .supreme-sidebar__link--active {
    text-decoration: underline;
  }

  /* ── Product Grid ── */
  .supreme-grid-area {
    background: #000;
    padding: 0;
  }

  .product-grid--supreme {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    padding: 0;
    margin: 0;
    list-style: none;
    background: #000;
  }

  @media screen and (max-width: 900px) {
    .product-grid--supreme { grid-template-columns: repeat(3, 1fr); }
  }
  @media screen and (max-width: 600px) {
    .product-grid--supreme { grid-template-columns: repeat(2, 1fr); }
  }

  .product-grid--supreme > li {
    display: block;
    background: #000;
    max-width: none;
    width: auto;
    padding: 0;
    margin: 0;
  }

  /* ── Full-Bleed Product Card with Hover Overlay ── */
  .supreme-product-card {
    display: block;
    background: #000;
    border: none;
    padding: 0;
    cursor: pointer;
    position: relative;
  }

  .supreme-product-card__image-wrap {
    display: block;
    background: #111;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    position: relative;
  }

  .supreme-product-card__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .supreme-product-card:hover .supreme-product-card__image-wrap img {
    transform: scale(1.03);
  }

  /* Hover overlay: gradient + text */
  .supreme-product-card__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 40px 10px 10px 10px;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0) 100%);
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .supreme-product-card:hover .supreme-product-card__overlay {
    opacity: 1;
  }

  /* On touch devices, always show overlay */
  @media (hover: none) {
    .supreme-product-card__overlay {
      opacity: 1;
    }
  }

  .supreme-product-card__title {
    font-family: Arial, Helvetica, "Helvetica Neue", sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: #fff;
    margin: 0 0 2px 0;
    line-height: 1.3;
    text-decoration: none;
    display: block;
  }

  .supreme-product-card__price {
    font-family: Arial, Helvetica, "Helvetica Neue", sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    display: block;
  }

  .supreme-product-card__sold-out {
    font-size: 12px;
    color: #999;
  }

  /* ── Loading ── */
  .loading-overlay { background: #000 !important; }

  /* ── Empty state ── */
  .supreme-empty {
    padding: 40px 20px;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    color: #fff;
  }
{%- endstyle -%}

{%- paginate collection.products by section.settings.products_per_page -%}

<div class="supreme-collection-layout">
  {%- comment -%} ── Left Sidebar Category Nav ── {%- endcomment -%}
  <aside class="supreme-sidebar" aria-label="Categories">
    <nav class="supreme-sidebar__nav">
      {%- comment -%}
        Dynamic sidebar: always show NEW first, then any collection that
        isn't a drop-* collection and isn't the reserved system handles
        (frontpage, staff-picks, home-page), then ALL last.
        New descriptive collections (e.g. "Workshop Desk", "Camera Gear")
        created per photo drop will appear here automatically.
      {%- endcomment -%}

      {%- assign system_handles = 'new,all,frontpage,staff-picks,home-page' | split: ',' -%}

      {%- comment -%} 1. NEW always first {%- endcomment -%}
      <a href="/collections/new"
        class="supreme-sidebar__link{% if collection.handle == 'new' %} supreme-sidebar__link--active{% endif %}"
      >NEW</a>

      {%- comment -%} 2. Dynamic descriptive collections (skip drop-* and system handles) {%- endcomment -%}
      {%- for col in collections -%}
        {%- assign h = col.handle -%}
        {%- assign skip = false -%}
        {%- if h contains 'drop-' -%}{%- assign skip = true -%}{%- endif -%}
        {%- for sys in system_handles -%}
          {%- if h == sys -%}{%- assign skip = true -%}{%- endif -%}
        {%- endfor -%}
        {%- unless skip -%}
          <a href="{{ col.url }}"
            class="supreme-sidebar__link{% if collection.handle == h %} supreme-sidebar__link--active{% endif %}"
          >{{ col.title | upcase }}</a>
        {%- endunless -%}
      {%- endfor -%}

      {%- comment -%} 3. ALL always last {%- endcomment -%}
      <a href="/collections/all"
        class="supreme-sidebar__link{% if collection.handle == 'all' %} supreme-sidebar__link--active{% endif %}"
      >ALL</a>
    </nav>
  </aside>

  {%- comment -%} ── Product Grid ── {%- endcomment -%}
  <div class="supreme-grid-area">
    <div class="loading-overlay gradient"></div>

    {%- if collection.products.size == 0 -%}
      <div class="supreme-empty">
        {{ 'sections.collection_template.empty' | t }}<br>
        <a href="{{ collection.url }}" class="underlined-link">{{ 'sections.collection_template.use_fewer_filters_html' | t: link: collection.url, class: 'underlined-link link' }}</a>
      </div>
    {%- else -%}
      <ul
        id="product-grid"
        data-id="{{ section.id }}"
        class="product-grid--supreme"
      >
        {%- for product in collection.products -%}
          {%- assign lazy_load = true -%}
          {%- if forloop.index <= 8 -%}{%- assign lazy_load = false -%}{%- endif -%}
          <li class="supreme-grid-item">
            <a href="{{ product.url }}" class="supreme-product-card" aria-label="{{ product.title | escape }}">
              <div class="supreme-product-card__image-wrap">
                {%- if product.featured_media -%}
                  <img
                    srcset="
                      {%- if product.featured_media.width >= 360 -%}{{ product.featured_media | image_url: width: 360 }} 360w,{%- endif -%}
                      {%- if product.featured_media.width >= 533 -%}{{ product.featured_media | image_url: width: 533 }} 533w,{%- endif -%}
                      {%- if product.featured_media.width >= 720 -%}{{ product.featured_media | image_url: width: 720 }} 720w,{%- endif -%}
                      {%- if product.featured_media.width >= 940 -%}{{ product.featured_media | image_url: width: 940 }} 940w,{%- endif -%}
                      {{ product.featured_media | image_url }} {{ product.featured_media.width }}w
                    "
                    src="{{ product.featured_media | image_url: width: 720 }}"
                    sizes="(min-width: 900px) 25vw, (min-width: 600px) 33vw, 50vw"
                    alt="{{ product.featured_media.alt | escape | default: product.title | escape }}"
                    {% unless lazy_load == false %}loading="lazy"{% endunless %}
                    width="{{ product.featured_media.width }}"
                    height="{{ product.featured_media.height }}"
                  >
                {%- else -%}
                  {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
                <div class="supreme-product-card__overlay">
                  <span class="supreme-product-card__title">{{ product.title }}</span>
                  <span class="supreme-product-card__price">
                    {%- if product.available -%}
                      {{ product.price | money }}
                    {%- else -%}
                      <span class="supreme-product-card__sold-out">Sold Out</span>
                    {%- endif -%}
                  </span>
                </div>
              </div>
            </a>
          </li>
        {%- endfor -%}
      </ul>

      {%- if paginate.pages > 1 -%}
        {% render 'pagination', paginate: paginate, anchor: '' %}
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

{%- endpaginate -%}

{% schema %}
{
  "name": "Collection products",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 96,
      "step": 4,
      "default": 48,
      "label": "Products per page"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Section top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Section bottom padding",
      "default": 0
    }
  ]
}
{% endschema %}
